[Unit]
Description=CRAFT Screenwriting Suite
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/baal-agent/workspace/agnes-video-generator
ExecStart=/opt/baal-agent/workspace/agnes-video-generator/.venv/bin/python3 craft_api.py
Environment=PATH=/opt/baal-agent/workspace/agnes-video-generator/.venv/bin:/usr/bin:/bin
Environment=AGNES_API_KEY=%{_agnes_api_key}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
